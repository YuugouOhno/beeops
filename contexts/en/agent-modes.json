{
  "modes": {
    "BO_QUEEN": {
      "context": ["queen.md"],

      "description": "beeops L1: Queen (orchestrator)"
    },
    "BO_LEADER": {
      "context": ["leader.md"],

      "description": "beeops L2: Leader (implementation lead)"
    },
    "BO_REVIEW_LEADER": {
      "context": ["review-leader.md"],

      "description": "beeops L2: Review Leader (review lead)"
    },
    "BO_WORKER_CODER": {
      "context": ["worker-base.md", "coder.md"],

      "description": "beeops L3: Worker (implementation)"
    },
    "BO_WORKER_TESTER": {
      "context": ["worker-base.md", "tester.md"],

      "description": "beeops L3: Worker (test writing)"
    },
    "BO_WORKER_CODE_REVIEWER": {
      "context": ["reviewer-base.md", "code-reviewer.md"],

      "description": "beeops L3: Worker (code review)"
    },
    "BO_WORKER_SECURITY": {
      "context": ["reviewer-base.md", "security-reviewer.md"],

      "description": "beeops L3: Worker (security review)"
    },
    "BO_WORKER_TEST_AUDITOR": {
      "context": ["reviewer-base.md", "test-auditor.md"],

      "description": "beeops L3: Worker (test audit)"
    },
    "BO_CONTENT_QUEEN": {
      "context": ["content-queen.md"],
      "description": "bee-content L1: Content Queen (orchestrator)"
    },
    "BO_CONTENT_LEADER": {
      "context": ["content-leader.md"],
      "description": "bee-content L2: Content Leader (piece director)"
    },
    "BO_CONTENT_CREATOR": {
      "context": ["content-creator.md"],
      "description": "bee-content L3: Worker (content creation)"
    },
    "BO_CONTENT_REVIEWER": {
      "context": ["content-reviewer.md"],
      "description": "bee-content L3: Worker (content review)"
    },
    "BO_CONTENT_RESEARCHER": {
      "context": ["content-researcher.md"],
      "description": "bee-content L3: Worker (research)"
    }
  },
  "roles": {
    "leader": {
      "env_var": "BO_LEADER",
      "allowed_tools": "Read Write Edit Bash Glob Grep Skill",
      "max_turns": 80,
      "description": "beeops: implementation lead for an Issue"
    },
    "review-leader": {
      "env_var": "BO_REVIEW_LEADER",
      "allowed_tools": "Read Grep Glob Bash Skill",
      "max_turns": 40,
      "description": "beeops: review lead for a PR"
    },
    "worker-coder": {
      "env_var": "BO_WORKER_CODER",
      "allowed_tools": "Read Write Edit Bash Glob Grep Skill",
      "max_turns": 30,
      "description": "beeops: single subtask implementation"
    },
    "worker-tester": {
      "env_var": "BO_WORKER_TESTER",
      "allowed_tools": "Read Write Edit Bash Glob Grep Skill",
      "max_turns": 30,
      "description": "beeops: test writing for a subtask"
    },
    "worker-code-reviewer": {
      "env_var": "BO_WORKER_CODE_REVIEWER",
      "allowed_tools": "Read Grep Glob Bash Skill",
      "max_turns": 15,
      "description": "beeops: code quality review"
    },
    "worker-security": {
      "env_var": "BO_WORKER_SECURITY",
      "allowed_tools": "Read Grep Glob Bash Skill",
      "max_turns": 15,
      "description": "beeops: security review"
    },
    "worker-test-auditor": {
      "env_var": "BO_WORKER_TEST_AUDITOR",
      "allowed_tools": "Read Grep Glob Bash Skill",
      "max_turns": 15,
      "description": "beeops: test audit"
    },
    "content-queen": {
      "env_var": "BO_CONTENT_QUEEN",
      "allowed_tools": "Read Write Edit Bash Glob Grep Skill",
      "max_turns": 80,
      "description": "bee-content: orchestrates all content creation tasks"
    },
    "content-leader": {
      "env_var": "BO_CONTENT_LEADER",
      "allowed_tools": "Read Write Edit Bash Glob Grep Skill",
      "max_turns": 50,
      "description": "bee-content: directs a single piece of content"
    },
    "content-creator": {
      "env_var": "BO_CONTENT_CREATOR",
      "allowed_tools": "Read Write Edit Bash Glob Grep",
      "max_turns": 30,
      "description": "bee-content: content creation worker"
    },
    "content-reviewer": {
      "env_var": "BO_CONTENT_REVIEWER",
      "allowed_tools": "Read Bash Glob Grep",
      "max_turns": 20,
      "description": "bee-content: content review worker"
    },
    "content-researcher": {
      "env_var": "BO_CONTENT_RESEARCHER",
      "allowed_tools": "Read Bash Glob Grep WebSearch WebFetch",
      "max_turns": 20,
      "description": "bee-content: research and information gathering worker"
    }
  },
  "default_context": "default.md"
}
